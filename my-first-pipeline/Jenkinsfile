pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/manassonu/Jenkins-Zero-To-Hero.git', branch: 'main'
            }
        }

        stage('Setup Kubernetes') {
            steps {
                sh '''
                  # Install kubectl if not already present
                  if ! command -v kubectl >/dev/null 2>&1; then
                    curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
                    install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
                  fi
                '''
            }
        }

        stage('Run Pod') {
            steps {
                // Apply a simple pod manifest
                writeFile file: 'pod.yml', text: '''
apiVersion: v1
kind: Pod
metadata:
  name: my-simple-pod
spec:
  containers:
  - name: my-container
    image: nginx:latest
    ports:
    - containerPort: 80
'''
                sh 'kubectl apply -f pod.yml'
                sh 'kubectl get pods'
            }
        }
    }
}
