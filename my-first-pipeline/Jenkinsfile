pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/manassonu/Jenkins-Zero-To-Hero.git', branch: 'main'
            }
        }

        stage('Setup Kubernetes') {
            steps {
                sh '''
                  mkdir -p $WORKSPACE/bin
                  curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
                  mv kubectl $WORKSPACE/bin/kubectl
                  chmod +x $WORKSPACE/bin/kubectl
                  export PATH=$WORKSPACE/bin:$PATH
                '''
            }
        }

        stage('Run Pod') {
            agent {
                docker { image 'bitnami/kubectl:latest' }
            }
            steps {
                writeFile file: 'pod.yml', text: '''
apiVersion: v1
kind: Pod
metadata:
  name: my-simple-pod
spec:
  containers:
  - name: my-container
    image: nginx:latest
    ports:
    - containerPort: 80
'''
                sh 'kubectl apply -f pod.yml'
                sh 'kubectl get pods'
            }
        }
    }
}
